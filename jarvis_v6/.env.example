# JARVIS V6 — Night-Shift Overclock Protocol
# Copy this file to ".env" (same folder or your CWD) and fill in real values.
# ".env" is git-ignored. Real process environment variables always win over it.
#
# Workflow: fill in credentials, keep JARVIS_DRY_RUN=1, run `jarvis-v6-preflight`
# to confirm everything logs in, then flip the relevant live switch.

# --- Master safety switch ---------------------------------------------------
# 1 = nothing external is mutated (recommended for the first nights).
# 0 = tasks may delete mail / publish store changes (per-task gates still apply).
JARVIS_DRY_RUN=1

# --- Wake clock -------------------------------------------------------------
JARVIS_WAKE_HOUR=16
JARVIS_WAKE_MINUTE=0

# --- Mailbox hygiene (IMAP) -------------------------------------------------
JARVIS_IMAP_HOST=
JARVIS_IMAP_USER=
JARVIS_IMAP_PASSWORD=
JARVIS_IMAP_PORT=993
JARVIS_IMAP_INBOX=INBOX
JARVIS_IMAP_TRASH=Trash

# --- Supplier crawl ---------------------------------------------------------
# Comma-separated listing URLs.
JARVIS_SUPPLIER_SOURCES=

# --- Market trends ----------------------------------------------------------
# Path to a JSON feed of records (search_volume, growth, competition, margin).
JARVIS_TRENDS_FEED=
JARVIS_WINNERS_TOP_N=2

# --- Fashion Aura store (Shopify) -------------------------------------------
JARVIS_STORE_PRODUCTS=
JARVIS_STORE_DOMAIN=your-shop.myshopify.com
JARVIS_STORE_API_KEY=
# Second live gate — must be 1 for SEO to actually be pushed to the store.
JARVIS_STORE_CONFIRM_LIVE=0
